rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isLeagueMember(leagueId) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/leagueMembers/$(leagueId + '_' + request.auth.uid));
    }

    function leagueOf(leagueId) {
      return get(/databases/$(database)/documents/leagues/$(leagueId)).data;
    }

    function isCoCommissioner(leagueId) {
      let league = leagueOf(leagueId);
      return isSignedIn() &&
        (league.commissionerId == request.auth.uid ||
         (league.coCommissionerIds is list && league.coCommissionerIds.hasAny([request.auth.uid])));
    }

    function notModifying(fields) {
      return !resource.data.diff(request.resource.data).affectedKeys().hasAny(fields);
    }

    // ── Users ──────────────────────────────────────────────
    // Anyone signed in can read profiles (usernames/avatars/payment
    // handles are shown throughout the app). Users may only ever
    // edit their own profile, and never the stats/flags that are
    // only meant to change via bet-settlement Cloud Functions.
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSelf(userId);
      allow update: if isSelf(userId) &&
        notModifying(['wins', 'losses', 'dishonorable', 'dishonorableDebts']);
      allow delete: if false;
    }

    // ── Leagues ──────────────────────────────────────────────
    // Readable only by members. Created only via the createLeague
    // Cloud Function (mints the commissioner's leagueMembers doc in
    // the same transaction). Commissioners/co-commissioners may
    // update settings but never reassign ownership or the starting
    // Monies amount after the fact.
    match /leagues/{leagueId} {
      allow read: if isLeagueMember(leagueId);
      allow create: if false;
      allow update: if isCoCommissioner(leagueId) &&
        notModifying(['commissionerId', 'startingMonies']);
      allow delete: if false;
    }

    // ── League Members (holds Monies balances) ────────────────
    // This is the collection that actually stores Monies. No client
    // write may ever touch the `monies` field — created and adjusted
    // exclusively by Cloud Functions running with Admin privileges.
    // The only client-writable path is a commissioner promoting or
    // demoting a member's role, and even then never for the league's
    // top-level commissioner.
    match /leagueMembers/{memberId} {
      allow read: if isSignedIn() &&
        (resource.data.userId == request.auth.uid || isLeagueMember(resource.data.leagueId));
      allow create: if false;
      allow update: if isCoCommissioner(resource.data.leagueId) &&
        resource.data.userId != leagueOf(resource.data.leagueId).commissionerId &&
        resource.data.diff(request.resource.data).affectedKeys().hasOnly(['role']);
      allow delete: if isCoCommissioner(resource.data.leagueId) &&
        resource.data.userId != leagueOf(resource.data.leagueId).commissionerId;
    }

    // ── Bets ───────────────────────────────────────────────────
    // Readable by any member of the bet's league (the Feed and Any
    // Action board are intentionally league-wide, not participant-only).
    // Every bet lifecycle transition moves Monies, wins/losses, or a
    // dishonorable flag somewhere, so all writes happen exclusively
    // through Cloud Functions running atomic transactions.
    match /bets/{betId} {
      allow read: if isLeagueMember(resource.data.leagueId);
      allow write: if false;

      match /comments/{commentId} {
        allow read: if isLeagueMember(get(/databases/$(database)/documents/bets/$(betId)).data.leagueId);
        allow create: if isLeagueMember(get(/databases/$(database)/documents/bets/$(betId)).data.leagueId) &&
          request.resource.data.userId == request.auth.uid;
        allow update, delete: if false;
      }
    }

    // ── Reactions (doc id == betId) ──────────────────────────
    match /reactions/{betId} {
      allow read: if isLeagueMember(get(/databases/$(database)/documents/bets/$(betId)).data.leagueId);
      allow write: if isLeagueMember(get(/databases/$(database)/documents/bets/$(betId)).data.leagueId);
    }

    // ── Announcements ──────────────────────────────────────────
    match /announcements/{id} {
      allow read: if isLeagueMember(resource.data.leagueId);
      allow create: if isCoCommissioner(request.resource.data.leagueId) &&
        request.resource.data.commissionerId == request.auth.uid;
      allow update: if isCoCommissioner(resource.data.leagueId);
      allow delete: if false;
    }

    // ── Notifications ────────────────────────────────────────
    // Any signed-in user may queue a notification for another user
    // (that's how in-app bet/reaction/comment alerts get delivered).
    // Only the recipient may ever read it or flip it to read.
    match /notifications/{id} {
      allow read: if isSignedIn() && resource.data.toUserId == request.auth.uid;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource.data.toUserId == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow delete: if false;
    }
  }
}
